# Copy to .env and adjust. relayd reads RELAY_* env vars (see internal/config).

# Server identity - MUST match the PTR/forward DNS of the sending IP.
RELAY_HOSTNAME=mail.as135559.net.au

# Listeners (dev-friendly ports; production uses 443/587/465/25).
RELAY_HTTP_ADDR=:8080
RELAY_SUBMISSION_ADDR=:587
RELAY_SUBMISSIONS_ADDR=:465
RELAY_INBOUND_ADDR=:25

# Database.
RELAY_DATABASE_URL=postgres://relay:relay_dev_pw@127.0.0.1:5432/relay?sslmode=disable
RELAY_MAX_CONNS=10
RELAY_AUTO_MIGRATE=true

# 32-byte base64 key for AES-256-GCM at-rest encryption (DKIM keys, webhook secrets).
# Generate: head -c32 /dev/urandom | base64
RELAY_SECRET_KEY=

# Comma-separated static admin bearer tokens (break-glass / API / scripts).
RELAY_ADMIN_TOKENS=relay_dev_token

# Bootstrap local admin account for the WebUI (created on first boot if no
# admin users exist yet). Change the password from the Admin users screen after.
RELAY_ADMIN_USER=admin
RELAY_ADMIN_PASSWORD=change-me-at-least-8-chars

# Subnets allowed to AUTH on port 25 (CIDR, comma-separated).
RELAY_PORT25_AUTH_SUBNETS=

# storage for content-addressed message bodies.
RELAY_STORAGE_DIR=storage

RELAY_LOG_LEVEL=info

# TLS / Let's Encrypt (certmagic). When enabled, HTTP_ADDR serves HTTPS (use :443),
# an ACME HTTP-01 + redirect server runs on ACME_HTTP_ADDR (:80), and the SMTP
# listeners share the managed cert. Requires public DNS for HOSTNAME + :80/:443
# reachable. Leave disabled for local dev (self-signed SMTP TLS, plaintext HTTP).
RELAY_TLS_ENABLED=false
RELAY_ACME_EMAIL=ops@as135559.net.au
RELAY_ACME_STAGING=false
RELAY_ACME_HTTP_ADDR=:80
# RELAY_ACME_CA=            # override directory URL (e.g. Pebble for tests)

# Load-test sink: route ALL outbound delivery to this host:port (skips MX).
# Leave empty in production.
RELAY_SMTP_SINK=
